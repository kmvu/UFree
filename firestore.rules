rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
      
      // Availability Collection
      match /availability/{date} {
        allow read: if request.auth != null; // Friends need to read this
        allow write: if request.auth.uid == userId && isValidAvailability();
      }
      
      // Notifications Collection
      match /notifications/{docId} {
        allow read: if request.auth.uid == userId;
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
        allow update: if request.auth.uid == userId; // To mark as read
        allow delete: if request.auth.uid == userId;
      }
    }
    
    // Validation Functions
    function isValidAvailability() {
      let data = request.resource.data;
      return data.size() <= 10 // Basic safety check for document size
        && (data.timeBlocks == null || (data.timeBlocks is list && data.timeBlocks.size() <= 10)) // Max 10 blocks
        && allBlocksValid(data.timeBlocks);
    }
    
    function allBlocksValid(blocks) {
      return blocks == null || blocks.all(block => 
        block.startTime is timestamp && 
        block.endTime is timestamp && 
        block.startTime < block.endTime &&
        block.status is int && block.status >= 0 && block.status <= 5
      );
    }
  }
}
